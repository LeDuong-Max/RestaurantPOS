<Window x:Class="WPF.ManagerAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Quản Lý Nhân Sự" Height="600" Width="1000" WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Danh sách Tài khoản" Grid.Column="0" Margin="0,0,10,0" FontSize="14" FontWeight="Bold">
            <DataGrid Name="dgAccounts" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionChanged="dgAccounts_SelectionChanged"
                      Margin="5" TextElement.FontSize="13" TextElement.FontWeight="Normal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên Đăng Nhập" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="1.5*"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding RoleNavigation.RoleName}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Header="Thông tin chi tiết" Grid.Column="1" FontSize="14" FontWeight="Bold">
            <StackPanel Margin="10" TextElement.FontSize="13" TextElement.FontWeight="Normal">

                <TextBlock Text="Tên đăng nhập (Username):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Name="txtUsername" Height="30" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Mật khẩu:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <PasswordBox Name="txtPassword" Height="30" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Họ và tên:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Name="txtFullName" Height="30" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Email liên hệ:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Name="txtEmail" Height="30" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Chức vụ (Role):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <ComboBox Name="cbRole" Height="30" Padding="5" Margin="0,0,0,15" DisplayMemberPath="RoleName" SelectedValuePath="RoleId"/>

                <TextBlock Text="Trạng thái (1: Hoạt động, 0: Khóa):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Name="txtStatus" Height="30" Padding="5" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Name="btnAdd" Content="THÊM MỚI" Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" Height="35" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="btnAdd_Click"/>
                    <Button Name="btnUpdate" Content="CẬP NHẬT" Grid.Row="0" Grid.Column="1" Margin="5,0,0,5" Height="35" Background="#FF9800" Foreground="White" FontWeight="Bold" Click="btnUpdate_Click"/>

                    <Button Name="btnDelete" Content="KHÓA / MỞ" Grid.Row="1" Grid.Column="0" Margin="0,5,5,0" Height="35" Background="#F44336" Foreground="White" FontWeight="Bold" Click="btnDelete_Click"/>
                    <Button Name="btnClear" Content="LÀM MỚI FORM" Grid.Row="1" Grid.Column="1" Margin="5,5,0,0" Height="35" Background="#9E9E9E" Foreground="White" FontWeight="Bold" Click="btnClear_Click"/>
                    <Button x:Name="btnClose" Content="Đóng" Width="120" Height="40" 
                            Background="#757575" Foreground="White" FontWeight="Bold" FontSize="14"
                            Click="btnClose_Click" Grid.ColumnSpan="2" Margin="120,40,120,-40" Grid.Row="1"/>
                </Grid>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>