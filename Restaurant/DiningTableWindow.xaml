<Window x:Class="WPF.DiningTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Sơ Đồ Bàn Ăn" Height="520" Width="800"
        WindowStartupLocation="CenterScreen" 
        Closed="Window_Closed">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <TextBlock Text="🎯 SƠ ĐỒ BÀN ĂN" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Width="20" Height="20" Background="#4CAF50" CornerRadius="5" Margin="0,0,5,0"/>
                    <TextBlock Text="Bàn trống" FontSize="16" FontWeight="SemiBold" Margin="0,0,20,0" VerticalAlignment="Center"/>

                    <Border Width="20" Height="20" Background="#F44336" CornerRadius="5" Margin="0,0,5,0"/>
                    <TextBlock Text="Đang có khách" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    
                    <Button Name="btnClose" Content="Đóng" Width="80" Height="30" Margin="20,0,0,0"
                            Background="#757575" Foreground="White" FontWeight="Bold" Click="btnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="icTables">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="140" Height="140" Margin="15" Tag="{Binding}" Click="btnTable_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10" 
                                                        BorderBrush="#DEE2E6" BorderThickness="2">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="🍽️" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                                        <TextBlock Text="{Binding TableName}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                            <Setter Property="Background" Value="#F44336"/>
                                        </DataTrigger>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>