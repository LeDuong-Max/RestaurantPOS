<Window x:Class="Restaurant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
            <Button Name="btnProfile" Content="Thông tin cá nhân" 
                Width="120" Height="30" Margin="0,0,10,0" 
                Click="btnProfile_Click" 
                Background="#4CAF50" Foreground="White" FontWeight="Bold" />

            <Button Name="btnManagerAccount" Content="Quản lí tài khoản" 
                Width="120" Height="30" Margin="0,0,10,0"
                Click="btnManagerAccount_Click" 
                Background="#2196F3" Foreground="White" FontWeight="Bold"/>
            
            <Button x:Name="btnLogout" Content="Đăng xuất" 
                Width="100" Height="30" 
                Click="btnLogout_Click" 
                Background="#FF5722" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
