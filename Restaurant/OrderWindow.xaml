<Window x:Class="Restaurant.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant"
        mc:Ignorable="d"
        Title="OrderWindow" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F2F5">
        <Grid.ColumnDefinitions>
            <!-- Cột trái: Hóa đơn của bàn (Chiếm 4 phần) -->
            <ColumnDefinition Width="4*"/>
            <!-- Cột phải: Danh sách Menu (Chiếm 6 phần) -->
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= KHU VỰC BÊN TRÁI: CHI TIẾT HÓA ĐƠN ================= -->
        <Border Grid.Column="0" Background="White" Margin="10" Padding="15" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="5" Color="#DDDDDD" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtTableName" Text="Hóa đơn -  ..." FontSize="22" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15" Height="29" VerticalAlignment="Bottom"/>

                <!-- Bảng hiển thị các món khách đã gọi -->
                <DataGrid x:Name="dgOrderDetails" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="White" BorderBrush="#EEE" BorderThickness="1" RowHeight="35" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên món" Width="*" Binding="{Binding FoodName}"/>
                        <DataGridTextColumn Header="SL" Width="50" Binding="{Binding Quantity}"/>
                        <DataGridTextColumn Header="Đơn giá" Width="80" Binding="{Binding UnitPrice}"/>
                        <DataGridTextColumn Header="Thành tiền" Width="90" Binding="{Binding TotalPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Khu vực tổng tiền và thanh toán -->
                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                    <Separator Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                        <TextBlock Text="Tổng cộng: " FontSize="18" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock x:Name="txtTotalPrice" Text="0 VNĐ" FontSize="18" FontWeight="Bold" Foreground="#E53935"/>
                    </StackPanel>

                    <Button x:Name="btnPayment" Content="THANH TOÁN" Height="45" Background="#4CAF50" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Click="btnPayment_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= KHU VỰC BÊN PHẢI: MENU THỰC ĐƠN ================= -->
        <Border Grid.Column="1" Background="White" Margin="0,10,10,10" Padding="15" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="5" Color="#DDDDDD" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Dòng 0: Tiêu đề -->
                    <RowDefinition Height="Auto"/>
                    <!-- Dòng 1: ComboBox Lọc (Mới chèn) -->
                    <RowDefinition Height="*"/>
                    <!-- Dòng 2: Danh sách món -->
                </Grid.RowDefinitions>

                <TextBlock Text="Thực Đơn (Menu)" FontSize="22" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                <!-- COMBOBOX LỌC MÓN ĂN -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Danh mục: " VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#555"/>
                    <ComboBox x:Name="cboCategory" Width="200" Height="32" Margin="10,0,0,0" FontSize="14"
                          DisplayMemberPath="CategoryName" 
                          SelectedValuePath="CategoryId" 
                          SelectionChanged="cboCategory_SelectionChanged"/>
                    <!-- Chỉ cần chèn thêm lại dòng này -->
                </StackPanel>

                <!-- Danh sách các món ăn để click chọn (Đã được chuyển xuống Grid.Row="2") -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="icMenu">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Nút bấm chứa Ảnh, Tên món và Giá -->
                                <Button Width="130" Height="160" Margin="5" Tag="{Binding}" Click="btnFoodItem_Click" 
                                        Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5">
                                        <Image Source="{Binding Img}" Width="100" Height="70" Stretch="UniformToFill" Margin="0,0,0,8">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,100,70" RadiusX="5" RadiusY="5"/>
                                            </Image.Clip>
                                        </Image>
                                        <TextBlock Text="{Binding FoodName}" TextWrapping="Wrap" TextAlignment="Center" 
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1565C0"/>

                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} đ}" TextAlignment="Center" 
                                                   FontSize="14" FontWeight="Bold" Foreground="#E53935" Margin="0,5,0,0"/>
                                    </StackPanel>

                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
