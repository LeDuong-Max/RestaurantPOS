<Window x:Class="Restaurant.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thống Kê &amp; Báo Cáo Doanh Thu" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Phần Lọc Ngày -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpFromDate" Width="120"/>
            
            <TextBlock Text="Đến ngày:" VerticalAlignment="Center" Margin="20,0,10,0"/>
            <DatePicker x:Name="dpToDate" Width="120"/>
            
            <Button x:Name="btnFilter" Content="Lọc Dữ Liệu" Width="100" Margin="20,0,0,0" Padding="5" Click="btnFilter_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- Nội dung chính (2 Tabs) -->
        <TabControl x:Name="tabMain" Grid.Row="1">
            <!-- Tab 1: Doanh Thu -->
            <TabItem Header="Báo Cáo Doanh Thu">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgRevenue" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ" Binding="{Binding OrderId}" Width="80"/>
                            <DataGridTextColumn Header="Bàn" Binding="{Binding Table.TableName}" Width="100"/>
                            <DataGridTextColumn Header="Thu ngân" Binding="{Binding Account.FullName}" Width="150"/>
                            <DataGridTextColumn Header="Giờ vào" Binding="{Binding OrderDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Giờ ra (Thanh toán)" Binding="{Binding CheckoutDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Giảm giá" Binding="{Binding Discount}" Width="100"/>
                            <DataGridTextColumn Header="Thành tiền" Binding="{Binding TotalPrice}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="TỔNG DOANH THU:" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtTotalRevenue" Text="0 VNĐ" FontSize="20" FontWeight="Bold" Foreground="Red" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Món Ăn Bán Chạy -->
            <TabItem Header="Món Ăn Bán Chạy (Top-sellers)">
                <Grid Margin="10">
                    <DataGrid x:Name="dgTopSelling" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Món" Binding="{Binding FoodId}" Width="100"/>
                            <DataGridTextColumn Header="Tên Món Ăn" Binding="{Binding FoodName}" Width="*"/>
                            <DataGridTextColumn Header="Số Lượng Đã Bán" Binding="{Binding TotalQuantitySold}" Width="150"/>
                            <DataGridTextColumn Header="Tổng Tiền Thu Về" Binding="{Binding TotalRevenue}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <!-- Nút Quay lại -->
            <Button x:Name="btnBack" Content="⬅ Quay lại Trang chủ" Width="180" Height="40" HorizontalAlignment="Left" Click="btnBack_Click" Background="#7F8C8D" Foreground="White" FontWeight="Bold"/>
            
            <!-- Xuất Báo Cáo -->
            <Button x:Name="btnExportCsv" Content="Xuất ra Excel (CSV)" Width="150" Height="40" HorizontalAlignment="Right" Click="btnExportCsv_Click" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>
