<Window x:Class="Restaurant.FoodItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant"
        mc:Ignorable="d"
        Title="Quản lý Món ăn" Height="500" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Bên trái: DataGrid -->
        <DataGrid x:Name="dgFoodItems" Grid.Column="0" AutoGenerateColumns="False" 
                  SelectionChanged="dgFoodItems_SelectionChanged" IsReadOnly="True" Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Món" Binding="{Binding FoodId}" Width="80"/>
                <DataGridTextColumn Header="Tên Món Ăn" Binding="{Binding FoodName}" Width="*"/>
                <DataGridTextColumn Header="Đơn Giá" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Danh Mục" Binding="{Binding Category.CategoryName}" Width="150"/>
                <DataGridCheckBoxColumn Header="Đang bán" Binding="{Binding IsAvailable}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bên phải: Form nhập liệu -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="THÔNG TIN MÓN ĂN" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Mã món ăn:" Margin="0,5,0,5"/>
            <TextBox x:Name="txtFoodId" IsReadOnly="True" Background="#EEEEEE" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Tên món ăn:" Margin="0,15,0,5"/>
            <TextBox x:Name="txtFoodName" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Đơn giá (VNĐ):" Margin="0,15,0,5"/>
            <TextBox x:Name="txtPrice" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Danh mục:" Margin="0,15,0,5"/>
            <!-- ComboBox quan trọng: ItemsSource nạp danh sách, DisplayMemberPath hiển thị tên, SelectedValuePath lấy ID -->
            <ComboBox x:Name="cbCategory" Height="30" VerticalContentAlignment="Center" Padding="5,0" 
                      DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId"/>

            <CheckBox x:Name="chkIsAvailable" Content="Món ăn đang được bán" IsChecked="True" Margin="0,15,0,0" FontWeight="Bold" Foreground="Green"/>

            <WrapPanel HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button x:Name="btnAdd" Content="Thêm" Width="70" Height="35" Margin="5" Click="btnAdd_Click"/>
                <Button x:Name="btnUpdate" Content="Sửa" Width="70" Height="35" Margin="5" Click="btnUpdate_Click"/>
                <Button x:Name="btnDelete" Content="Xóa" Width="70" Height="35" Margin="5" Click="btnDelete_Click"/>
            </WrapPanel>

            <Button x:Name="btnClear" Content="Làm mới" Height="35" Margin="5,15,5,0" Click="btnClear_Click"/>
            <Button x:Name="btnBack" Content="⬅ Quay lại" Height="35" Margin="5,15,5,0" Click="btnBack_Click" Background="#7F8C8D" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
