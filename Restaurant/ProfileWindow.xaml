<Window x:Class="WPF.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Thông Tin Cá Nhân" Height="520" Width="800"
        WindowStartupLocation="CenterOwner" 
        Closed="Window_Closed">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="👤 THÔNG TIN HỒ SƠ" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25" Foreground="#007ACC"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Tên đăng nhập:" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBlock Name="txtUsername" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Chức vụ:" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBlock Name="txtRole" FontSize="16" FontWeight="Bold" Foreground="#E53935"/>
                </StackPanel>
            </Grid>

            <Separator Margin="0,10,0,20" Background="#DDDDDD"/>

            <TextBlock Text="Họ và tên:" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Name="txtFullName" FontSize="16" Height="35" Padding="5" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Email liên hệ:" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Name="txtEmail" FontSize="16" Height="35" Padding="5" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Mật khẩu mới (Để trống nếu không muốn đổi):" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,5"/>
            <PasswordBox Name="txtPassword" FontSize="16" Height="35" Padding="5" VerticalContentAlignment="Center" Margin="0,0,0,30"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="btnSave" Content="LƯU THAY ĐỔI" Width="140" Height="40" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,20,0"
                        Click="btnSave_Click"/>

                <Button Name="btnClose" Content="HỦY BỎ" Width="120" Height="40" 
                        Background="#757575" Foreground="White" FontWeight="Bold" FontSize="14"
                        Click="btnClose_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>