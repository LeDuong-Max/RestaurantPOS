<Window x:Class="WPF.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Login" Height="520" Width="800">
    <Grid>
        <StackPanel Width="300" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ĐĂNG NHẬP" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Tên đăng nhập:" Margin="0,5"/>
            <TextBox Name="txtUsername" Height="30"/>

            <TextBlock Text="Mật khẩu:" Margin="0,5"/>
            <PasswordBox Name="txtPassword" Height="30"/>

            <Button Name="btnLogin" Content="ĐĂNG NHẬP" 
    Height="40" Margin="0,20,0,0" 
    Background="#007ACC" Foreground="White" 
    FontWeight="Bold" 
    Click="btnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>
